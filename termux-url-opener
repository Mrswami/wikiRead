#!/bin/bash
# termux-url-opener
# Triggered when a URL is shared to Termux from another app.

# Detect the Wikipedia URL from any part of the shared string
# (The Wikipedia app sometimes shares 'Title - https://en.wikipedia... ')
INPUT="$*"
URL=$(echo "$INPUT" | grep -o 'https://[^ ]*wikipedia.org/[^ ]*' | head -1)

# Fallback if the above regex is too strict
if [ -z "$URL" ]; then
    URL=$(echo "$INPUT" | grep -o 'http[^ ]*wikipedia.org[^ ]*' | head -1)
fi

# Final fallback to $1 if regex fails but $1 looks okay
if [ -z "$URL" ] && [[ "$1" == *"wikipedia.org"* ]]; then
    URL="$1"
fi

if [ -z "$URL" ]; then
    echo "No Wikipedia URL found in: $INPUT"
    echo "wikiRead only supports Wikipedia links."
    read -p "Press Enter to exit..."
    exit 0
fi

echo "📖 wikiRead: Starting server for $URL"

# Kill any existing Flask instance on our port
pkill -f "python3 $APP_DIR/app.py" 2>/dev/null

# Start Flask server in background
cd "$APP_DIR"
python3 app.py &
SERVER_PID=$!

# Give the server a moment to start
sleep 2

# URL-encode the wikipedia URL for the query param
ENCODED_URL=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$URL")

# Open the reader in the default browser
termux-open-url "http://localhost:$PORT/read?url=$ENCODED_URL"

echo "✅ Server running (PID $SERVER_PID). Browser opened."
echo "   Close this terminal when done."
wait $SERVER_PID

