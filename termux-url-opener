#!/bin/bash
# termux-url-opener
# Triggered when a URL is shared to Termux from another app.

# 1. Extract URL (Wikipedia app uses "Title - URL" format)
INPUT="$*"
# Improved regex to find any wikipedia link in the shared text
URL=$(echo "$INPUT" | grep -oEi 'https?://[a-z0-9.-]+\.wikipedia\.org/wiki/[^ ]+' | head -1)

# Status Check
if [ -z "$URL" ]; then
    termux-toast -c red -b white "wikiRead: No Wikipedia link found"
    echo "❌ Error: Could not find a Wikipedia link in: $INPUT"
    read -p "Press Enter to exit..."
    exit 1
fi

termux-toast "📖 wikiRead: Fetching Article..."

# 2. Kill old server instances on port 5000
# Using fuser is more reliable than pkill
fuser -k ${PORT}/tcp > /dev/null 2>&1

# 3. Start Flask server in background
cd "$APP_DIR"
# Run and redirect output to a log file for debugging
python3 app.py > "$HOME/wikiread_server.log" 2>&1 &
SERVER_PID=$!

# 4. Wait for server to wake up (max 5 seconds)
# We check the port instead of a fixed sleep
SUCCESS=0
for i in {1..10}; do
    if lsof -Pi :$PORT -sTCP:LISTEN -t >/dev/null ; then
        SUCCESS=1
        break
    fi
    sleep 0.5
done

# 5. Open Browser
if [ $SUCCESS -eq 1 ]; then
    ENCODED_URL=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$URL")
    termux-open-url "http://localhost:$PORT/read?url=$ENCODED_URL"
    termux-toast "✅ wikiRead Ready!"
else
    termux-toast -c red "❌ wikiRead: Server failed to start"
    echo "Error: Server failed to start. Check ~/wikiread_server.log"
    read -p "Press Enter to close..."
fi

exit 0

